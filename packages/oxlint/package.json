{
  "name": "@trigen/oxlint",
  "type": "module",
  "version": "9.1.0",
  "description": "Trigen's Oxlint config helper.",
  "author": "dangreen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TrigenSoftware/scripts.git",
    "directory": "packages/oxlint"
  },
  "bugs": {
    "url": "https://github.com/TrigenSoftware/scripts/issues"
  },
  "keywords": [
    "oxlint",
    "oxlint-config"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "directory": "package",
    "linkDirectory": false
  },
  "scripts": {
    "prepublishOnly": "del ./package && clean-publish",
    "postpublish": "del ./package"
  }
}
